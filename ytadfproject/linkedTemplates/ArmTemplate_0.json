{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ytadfproject"
		},
		"ProjectDBLinkedservice_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ProjectDBLinkedservice'"
		},
		"ProjectStorageLinkedservice_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ProjectStorageLinkedservice'"
		},
		"ProjectDBLinkedservice_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "ytprojectserver.database.windows.net"
		},
		"ProjectDBLinkedservice_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ytprojectdb"
		},
		"ProjectDBLinkedservice_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ytserveradmin"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ProjectDBLinkedservice')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('ProjectDBLinkedservice_properties_typeProperties_server')]",
					"database": "[parameters('ProjectDBLinkedservice_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ProjectDBLinkedservice_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ProjectDBLinkedservice_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ProjectStorageLinkedservice')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"connectionString": "[parameters('ProjectStorageLinkedservice_connectionString')]"
				}
			},
			"dependsOn": []
		}
	]
}