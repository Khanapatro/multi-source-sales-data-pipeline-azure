{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ytadfproject"
		},
		"ProjectDBLinkedservice_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ProjectDBLinkedservice'"
		},
		"ProjectStorageLinkedservice_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ProjectStorageLinkedservice'"
		},
		"ProjectDBLinkedservice_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "ytprojectserver.database.windows.net"
		},
		"ProjectDBLinkedservice_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ytprojectdb"
		},
		"ProjectDBLinkedservice_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ytserveradmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ytadfproject_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ProjectDBLinkedservice_password": {
						"value": "[parameters('ProjectDBLinkedservice_password')]"
					},
					"ProjectStorageLinkedservice_connectionString": {
						"value": "[parameters('ProjectStorageLinkedservice_connectionString')]"
					},
					"ProjectDBLinkedservice_properties_typeProperties_server": {
						"value": "[parameters('ProjectDBLinkedservice_properties_typeProperties_server')]"
					},
					"ProjectDBLinkedservice_properties_typeProperties_database": {
						"value": "[parameters('ProjectDBLinkedservice_properties_typeProperties_database')]"
					},
					"ProjectDBLinkedservice_properties_typeProperties_userName": {
						"value": "[parameters('ProjectDBLinkedservice_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}